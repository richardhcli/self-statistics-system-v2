{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    //With "baseUrl": "./", TypeScript will look for files starting at the same folder as the tsconfig.json:
    "baseUrl": "./",
    "paths": {
      "@web/*": [
        "./src/*"
      ],
      "@self-stats/contracts": ["../../shared/contracts/src/index.ts"],
      "@self-stats/progression-system": ["../../shared/progression-system/src/index.ts"],
      "@self-stats/soul-topology": ["../../shared/soul-topology/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}